# Backend Environment Variables
# Copy these to Render Environment Variables section

# Your Vercel frontend URL (replace with your actual Vercel URL)
FRONTEND_URL=https://your-app-name.vercel.app

# Flask environment (use 'production' for Render)
FLASK_ENV=production

# Port (Render sets this automatically)
PORT=10000

# Example:
# FRONTEND_URL=https://ethioprice-dashboard.vercel.app
# FLASK_ENV=production
# PORT=10000
